# ============================================================
# QR Service — Environment Variables
# SWEBOK v4: Software Configuration Management
# OWASP: Secrets NEVER committed to Git — use this as template only
# ============================================================
# Copy to .env and fill values. NEVER commit .env to Git.

# ── App ───────────────────────────────────────────────────────
APP_VERSION=1.0.0
ENVIRONMENT=production          # development | staging | production
DEBUG=false                     # MUST be false in production
ALLOWED_HOSTS=["qrservice.com","www.qrservice.com"]
CORS_ORIGINS=["https://qrservice.com"]
BASE_URL=https://qrservice.com

# ── Security ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ── Database ──────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=qr_service_db
POSTGRES_USER=qr_service_user
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME_redis_password

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_FREE_PER_MINUTE=10
RATE_LIMIT_ANNUAL_PER_MINUTE=100
RATE_LIMIT_ANON_PER_MINUTE=5

# ── Business Rules ────────────────────────────────────────────
FREE_PLAN_QR_LIMIT=5
FREE_PLAN_DURATION_DAYS=30
ANNUAL_PLAN_DURATION_DAYS=365
ANNUAL_PLAN_PRICE_USD=49.99

# ── Stripe ────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_ANNUAL_PRICE_ID=price_CHANGE_ME

# ── Email ─────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=CHANGE_ME_sendgrid_api_key
EMAILS_FROM=noreply@qrservice.com

# ── Monitoring ────────────────────────────────────────────────
SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME
GRAFANA_PASSWORD=CHANGE_ME_grafana_password

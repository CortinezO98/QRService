# ============================================================
# QR Service v2.0 — Variables de entorno
# NUEVO MODELO: FREE / STARTER ($10) / PRO ($20) / BUSINESS ($30)
# NUNCA subir este archivo con valores reales al repositorio
# ============================================================

# ── App ───────────────────────────────────────────────────────
APP_VERSION=2.0.0
ENVIRONMENT=production
DEBUG=false
BASE_URL=https://tudominio.com
ALLOWED_HOSTS=["tudominio.com","www.tudominio.com"]
CORS_ORIGINS=["https://tudominio.com"]

# ── Security ──────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_min_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ── Database ──────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=qr_service_db
POSTGRES_USER=qr_service_user
# Generar con: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_FREE_PER_MINUTE=10
RATE_LIMIT_PAID_PER_MINUTE=60
RATE_LIMIT_ANON_PER_MINUTE=5

# ── Plan FREE ─────────────────────────────────────────────────
FREE_PLAN_QR_QUOTA=1
FREE_PLAN_DURATION_DAYS=30
FREE_QR_EXPIRY_DAYS=30

# ── Plan STARTER — $10/año — 5 QR ────────────────────────────
STARTER_PLAN_QR_QUOTA=5
STARTER_PLAN_PRICE_USD=10.00
STARTER_PLAN_DURATION_DAYS=365

# ── Plan PRO — $20/año — 15 QR ───────────────────────────────
PRO_PLAN_QR_QUOTA=15
PRO_PLAN_PRICE_USD=20.00
PRO_PLAN_DURATION_DAYS=365

# ── Plan BUSINESS — $30/año — 30 QR ──────────────────────────
BUSINESS_PLAN_QR_QUOTA=30
BUSINESS_PLAN_PRICE_USD=30.00
BUSINESS_PLAN_DURATION_DAYS=365

# ── Stripe ────────────────────────────────────────────────────
# Obtener en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
# Crear 3 productos en Stripe y pegar los Price IDs aquí:
STRIPE_STARTER_PRICE_ID=price_CHANGE_ME_starter
STRIPE_PRO_PRICE_ID=price_CHANGE_ME_pro
STRIPE_BUSINESS_PRICE_ID=price_CHANGE_ME_business

# ── Email (SendGrid, SES, etc.) ───────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=CHANGE_ME
EMAILS_FROM=noreply@tudominio.com
EMAILS_FROM_NAME=QR Service

# ── Monitoring ────────────────────────────────────────────────
SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME
GRAFANA_PASSWORD=CHANGE_ME

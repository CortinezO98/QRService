# ============================================================
# QR-as-a-Service — Variables de entorno
# Copiar como .env y completar. NUNCA commitear .env al repo.
# ============================================================

# ── App ───────────────────────────────────────────────────────
ENVIRONMENT=production
APP_VERSION=2.1.0
DEBUG=false

# ── Seguridad ─────────────────────────────────────────────────
SECRET_KEY=CAMBIA_ESTO_minimo_64_caracteres_aleatorios
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
BCRYPT_ROUNDS=12

# ── CORS / Hosts ──────────────────────────────────────────────
CORS_ORIGINS=["https://tudominio.com"]
ALLOWED_HOSTS=["tudominio.com","www.tudominio.com"]

# ── URLs ──────────────────────────────────────────────────────
BASE_URL=https://tudominio.com
FRONTEND_URL=https://tudominio.com

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=qr_service
POSTGRES_USER=qr_user
POSTGRES_PASSWORD=CAMBIA_ESTO

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CAMBIA_ESTO
REDIS_DB=0

# ── Stripe — 4 planes ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_BUSINESS_PRICE_ID=price_...

# ── OAuth Google ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=https://tudominio.com/api/v1/auth/google/callback

# ── OAuth Facebook ────────────────────────────────────────────
FACEBOOK_CLIENT_ID=...
FACEBOOK_CLIENT_SECRET=...
FACEBOOK_REDIRECT_URI=https://tudominio.com/api/v1/auth/facebook/callback

# ── Email ─────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG....
EMAILS_FROM=noreply@tudominio.com
EMAILS_FROM_NAME=QR Service

# ── Plan FREE ─────────────────────────────────────────────────
FREE_PLAN_QR_QUOTA=1
FREE_PLAN_DURATION_DAYS=30

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_ANON_PER_MINUTE=20
RATE_LIMIT_FREE_PER_MINUTE=60

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_PASSWORD=CAMBIA_ESTO

# ── Sentry (opcional) ─────────────────────────────────────────
SENTRY_DSN=

# ── Frontend .env (copiar a qr-frontend/.env) ─────────────────
# VITE_API_URL=https://tudominio.com
